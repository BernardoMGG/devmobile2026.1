<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MetaFit"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#DEFF9A"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seu planejamento físico inteligente"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textAlignment="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnComecar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="COMEÇAR AVALIAÇÃO"
        android:textSize="18sp"
        android:backgroundTint="#DEFF9A"
        android:textColor="#121212"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnHistorico"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="VER HISTÓRICO"
        android:textSize="18sp"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

</LinearLayout>
